<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp"
    tools:context=".GenerateBills">

    <TextView
        android:id="@+id/create_product"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/oxygen"
        android:text="@string/generate_bill"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/scanned_product_id"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/oxygen"
        android:text="@string/scanned_id"
        android:textColor="#616161"
        android:textSize="14sp"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_product" />

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scanned_product_id" />

    <Button
        android:id="@+id/addProduct"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/oxygen"
        android:text="@string/add_product"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textColorHighlight="@color/white"
        android:textColorHint="@color/white"
        app:backgroundTint="@color/black"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toStartOf="@+id/save_bill"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/previewView" />

    <Button
        android:id="@+id/save_bill"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/oxygen"
        android:text="@string/save_bill"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textColorHighlight="@color/white"
        android:textColorHint="@color/white"
        app:backgroundTint="#2E7D32"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/addProduct"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/addProduct"
        app:layout_constraintTop_toTopOf="@+id/addProduct" />

    <View
        android:id="@+id/receipt_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addProduct" />

    <ScrollView
        android:id="@+id/billScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="3dp"
        android:padding="12dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="@id/receipt_bg"
        app:layout_constraintEnd_toEndOf="@id/receipt_bg"
        app:layout_constraintStart_toStartOf="@id/receipt_bg"
        app:layout_constraintTop_toTopOf="@id/receipt_bg">

        <TextView
            android:id="@+id/product_list_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/oxygen"
            android:textColor="#212121"
            android:textSize="16sp"
            tools:text="SUMMARY\n────────────────\nCoffee x 1 | Rs. 12.00" />
    </ScrollView>

    <TextView
        android:id="@+id/empty_text_view2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:fontFamily="@font/oxygen"
        android:text="@string/no_products_found"
        android:textColor="#BDBDBD"
        app:layout_constraintBottom_toBottomOf="@id/receipt_bg"
        app:layout_constraintEnd_toEndOf="@id/receipt_bg"
        app:layout_constraintStart_toStartOf="@id/receipt_bg"
        app:layout_constraintTop_toTopOf="@id/receipt_bg" />

</androidx.constraintlayout.widget.ConstraintLayout>