<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp"
    tools:context=".ViewBills">

    <TextView
        android:id="@+id/view_bills_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/oxygen"
        android:text="@string/ViewBills"
        android:textColor="@color/black"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtitle_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/oxygen"
        android:letterSpacing="0.1"
        android:text="PAST TRANSACTIONS"
        android:textAllCaps="true"
        android:textColor="#757575"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_bills_title" />

    <View
        android:id="@+id/bill_list_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle_history" />

    <ScrollView
        android:id="@+id/billScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="3dp"
        android:padding="12dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="@id/bill_list_container"
        app:layout_constraintEnd_toEndOf="@id/bill_list_container"
        app:layout_constraintStart_toStartOf="@id/bill_list_container"
        app:layout_constraintTop_toTopOf="@id/bill_list_container">

        <TextView
            android:id="@+id/product_list_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/oxygen"
            android:letterSpacing="0.02"
            android:lineSpacingExtra="8dp"
            android:textColor="#212121"
            android:textSize="15sp"
            tools:text="● BILL #102 | Rs. 450.00\n   Items: Coffee, Bread\n─────────────────" />
    </ScrollView>

    <TextView
        android:id="@+id/empty_text_view4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:fontFamily="@font/oxygen"
        android:text="@string/no_products_found"
        android:textColor="#BDBDBD"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/bill_list_container"
        app:layout_constraintEnd_toEndOf="@id/bill_list_container"
        app:layout_constraintStart_toStartOf="@id/bill_list_container"
        app:layout_constraintTop_toTopOf="@id/bill_list_container" />

</androidx.constraintlayout.widget.ConstraintLayout>